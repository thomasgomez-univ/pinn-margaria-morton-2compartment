# ============================================================
# Generated outputs (regenerable from source)
# ============================================================
# Generated figures (PDF + PNG); kept untracked because they
# can be regenerated by running the experiment scripts.
# Comment these lines out if you want to ship pre-generated figures.
figures/*.pdf
figures/*.png

# Numerical results (JSON, NumPy binaries)
results/*.json
results/*.npz
results/*.npy
results/*.pt
results/*.pth

# Synthetic datasets generated by the scripts
data/synthetic/*.csv
data/synthetic/*.json
data/synthetic/*.npz

# Logs and intermediate runs
logs/
runs/
mlruns/
wandb/
*.log
tmp/

